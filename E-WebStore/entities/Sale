{
  "name": "Sale",
  "type": "object",
  "properties": {
    "sale_number": {
      "type": "string",
      "description": "Unique sale reference number"
    },
    "customer_id": {
      "type": "string",
      "description": "Customer reference"
    },
    "customer_name": {
      "type": "string",
      "description": "Customer name for quick reference"
    },
    "subtotal": {
      "type": "number",
      "description": "Subtotal before tax and discount"
    },
    "tax_amount": {
      "type": "number",
      "description": "Tax amount"
    },
    "discount_amount": {
      "type": "number",
      "description": "Discount amount"
    },
    "total_amount": {
      "type": "number",
      "description": "Final total amount"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "cash",
        "card",
        "mobile",
        "mixed"
      ],
      "description": "Payment method used"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "refunded",
        "voided",
        "pending"
      ],
      "default": "completed"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes"
    },
    "items_data": {
      "type": "string",
      "description": "JSON string of sale items for receipt"
    }
  },
  "required": [
    "sale_number",
    "total_amount",
    "payment_method"
  ]
}